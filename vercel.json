{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/flowdeck build",
  "outputDirectory": "artifacts/flowdeck/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
